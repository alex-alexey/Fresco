# ============================================================
# FrescoEnVivo — Environment Variables
# ============================================================
# Copia este archivo como .env.local y rellena los valores.
# NUNCA comitees .env.local con valores reales.
# La app NO arrancará si alguna variable requerida falta.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- MongoDB Atlas ---
# URI de conexión al cluster. Incluye usuario, password y cluster.
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net
MONGODB_DB_NAME=frescoenvivo

# --- NextAuth ---
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_32_CHARS_MINIMUM
NEXTAUTH_URL=http://localhost:3000

# --- Upstash Redis (Rate Limiting) ---
# Obtener en: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# --- SMTP (Emails transaccionales) ---
# Ejemplo Mailtrap / SendGrid SMTP / Brevo SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=no-reply@frescoenvivo.com
SMTP_FROM_NAME=FrescoEnVivo
CUSTOM_DOMAIN_TARGET=domains.frescoenvivo.com

# --- Branding opcional para emails ---
BRAND_LOGO_URL=https://example.com/logo.png
BRAND_SUPPORT_URL=https://example.com/soporte
BRAND_INSTAGRAM_URL=https://instagram.com/tu_marca

# --- Superadmin inicial (solo para seed) ---
# Usado exclusivamente por el script de seed para crear el primer superadmin.
# Eliminar o dejar vacío después del primer deploy.
SUPERADMIN_INITIAL_EMAIL=admin@frescoenvivo.com
SUPERADMIN_INITIAL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
